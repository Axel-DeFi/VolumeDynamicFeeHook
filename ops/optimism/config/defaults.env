# Runtime mode for this profile.
OPS_RUNTIME=live
# Chain ID expected from the connected RPC.
CHAIN_ID_EXPECTED=10
# RPC endpoint used by Optimism ops flows.
RPC_URL=https://optimism-rpc.publicnode.com

# Private key used to sign Optimism transactions.
PRIVATE_KEY=${OPTIMISM_PRIVATE_KEY:-${DEFAULT_PRIVATE_KEY:-}}
# Deployer address used when signing happens outside this config.
DEPLOYER=
# Owner address for admin actions and HookFee withdrawals.
OWNER=${OPTIMISM_OWNER:-${DEFAULT_OWNER:-}}

# Runtime controller expectations for the target Optimism redeploy profile.
# *VOLUME values use the internal dollar scale with six implied decimals.
MIN_COUNTED_SWAP_VOLUME=4000000
FLOOR_TO_CASH_MIN_CLOSE_VOLUME=400000000
FLOOR_TO_CASH_MIN_FLOW_EMA_X=1.35
CASH_HOLD_PERIODS=2
CASH_TO_EXTREME_MIN_CLOSE_VOLUME=2500000000
CASH_TO_EXTREME_MIN_FLOW_EMA_X=4.10
CASH_TO_EXTREME_CONFIRM_PERIODS=2
EXTREME_HOLD_PERIODS=2
EXTREME_TO_CASH_MAX_FLOW_EMA_X=1.20
EXTREME_TO_CASH_CONFIRM_PERIODS=2
CASH_TO_FLOOR_MAX_FLOW_EMA_X=1.20
CASH_TO_FLOOR_CONFIRM_PERIODS=3
EMERGENCY_TO_FLOOR_MAX_CLOSE_VOLUME=100000000
EMERGENCY_TO_FLOOR_CONFIRM_PERIODS=6

# Minimum ETH balance required before running ops.
BUDGET_MIN_ETH_WEI=0
# Minimum stable-token balance required before running ops.
BUDGET_MIN_STABLE_RAW=0
# Minimum volatile-token balance required before running ops.
BUDGET_MIN_VOLATILE_RAW=0
# Stable-token amount reserved for liquidity provisioning.
BUDGET_LIQ_STABLE_RAW=0
# Volatile-token amount reserved for liquidity provisioning.
BUDGET_LIQ_VOLATILE_RAW=0
# Stable-token amount reserved for swap operations.
BUDGET_SWAP_STABLE_RAW=0
# Volatile-token amount reserved for swap operations.
BUDGET_SWAP_VOLATILE_RAW=0
# Extra ETH buffer reserved above explicit budgets.
BUDGET_SAFETY_BUFFER_ETH_WEI=0

# Helper swap driver contract used by live swap flows.
SWAP_DRIVER=
# Helper liquidity driver contract used by live liquidity flows.
LIQUIDITY_DRIVER=

# Stable-token amount used by smoke swaps.
SMOKE_SWAP_STABLE_RAW=0
# Stable-token amount used by full validation swaps.
FULL_SWAP_STABLE_RAW=0
# Number of swap iterations in the full validation flow.
FULL_SWAP_ITERATIONS=4
# Stable-token amount used by rerun-safe validation swaps.
RERUN_SWAP_STABLE_RAW=0

# Enables transaction broadcasting for this profile.
OPS_BROADCAST=0
