# Deployment snapshot and bootstrap inputs for this profile.
# Keep DEPLOY_* values aligned with the constructor args used for deployment.
# DEPLOY_* values must be literal and must not depend on shell expansion.

# Pool binding
# PoolManager address baked into the constructor snapshot.
DEPLOY_POOL_MANAGER=0x9a13F98Cb987694C9F086b1F5eB990EeA8264Ec3
# Volatile token address baked into the constructor snapshot.
DEPLOY_VOLATILE=0x0000000000000000000000000000000000000000
# Stable token address baked into the constructor snapshot.
DEPLOY_STABLE=0x0b2C639c533813f4Aa9D7837CAf62653d097Ff85
# Pool tick spacing baked into the constructor snapshot.
DEPLOY_TICK_SPACING=60

# Ownership
# Owner address baked into the constructor snapshot.
DEPLOY_OWNER=0x9343BAB7e334ba06167e7D2A7A6Cb1C4CcAAeF20

# LP fee modes
# FLOOR LP fee baked into the constructor snapshot, as a percent.
DEPLOY_FLOOR_FEE_PERCENT=0.04
# CASH LP fee baked into the constructor snapshot, as a percent.
DEPLOY_CASH_FEE_PERCENT=0.25
# EXTREME LP fee baked into the constructor snapshot, as a percent.
DEPLOY_EXTREME_FEE_PERCENT=0.9

# Timing
# Close period length baked into the constructor snapshot, in seconds.
DEPLOY_PERIOD_SECONDS=300
# EMA denominator baked into the constructor snapshot.
DEPLOY_EMA_PERIODS=36
# Idle time baked into the constructor snapshot, in seconds.
DEPLOY_IDLE_RESET_SECONDS=3300
# Additional trader fee baked into the constructor snapshot, as a percent of the active LP fee.
DEPLOY_HOOK_FEE_PERCENT=1

# Controller thresholds
# *VOLUME values use the internal dollar scale with six implied decimals.
# Minimum period volume baked into the constructor snapshot for FLOOR -> CASH.
DEPLOY_ENTER_CASH_MIN_VOLUME=400000000
# Minimum period-volume / EMA ratio baked into the constructor snapshot for FLOOR -> CASH, in percent.
DEPLOY_ENTER_CASH_EMA_RATIO_PERCENT=135
# Cash hold length baked into the constructor snapshot.
DEPLOY_HOLD_CASH_PERIODS=2
# Minimum period volume baked into the constructor snapshot for CASH -> EXTREME.
DEPLOY_ENTER_EXTREME_MIN_VOLUME=2500000000
# Minimum period-volume / EMA ratio baked into the constructor snapshot for CASH -> EXTREME, in percent.
DEPLOY_ENTER_EXTREME_EMA_RATIO_PERCENT=410
# Required confirming periods baked into the constructor snapshot for CASH -> EXTREME.
DEPLOY_ENTER_EXTREME_CONFIRM_PERIODS=2
# Extreme hold length baked into the constructor snapshot.
DEPLOY_HOLD_EXTREME_PERIODS=2
# Maximum period-volume / EMA ratio baked into the constructor snapshot for EXTREME -> CASH, in percent.
DEPLOY_EXIT_EXTREME_EMA_RATIO_PERCENT=120
# Required confirming periods baked into the constructor snapshot for EXTREME -> CASH.
DEPLOY_EXIT_EXTREME_CONFIRM_PERIODS=2
# Maximum period-volume / EMA ratio baked into the constructor snapshot for CASH -> FLOOR, in percent.
DEPLOY_EXIT_CASH_EMA_RATIO_PERCENT=120
# Required confirming periods baked into the constructor snapshot for CASH -> FLOOR.
DEPLOY_EXIT_CASH_CONFIRM_PERIODS=3
# Low-volume reset threshold baked into the constructor snapshot.
DEPLOY_LOW_VOLUME_RESET=100000000
# Required confirming periods baked into the constructor snapshot for the low-volume reset.
DEPLOY_LOW_VOLUME_RESET_PERIODS=6

# Pool bootstrap
# Initial pool price in USD used to initialize the pool onchain.
INIT_PRICE_USD=2182
