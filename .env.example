# Copy to ".env" and fill only the networks you use.
# `ops/*/config/defaults.env` already provides public RPC URLs.

# Optional shared fallbacks.
DEFAULT_PRIVATE_KEY=0xYOUR_DEFAULT_PRIVATE_KEY
DEFAULT_OWNER=0xYOUR_DEFAULT_OWNER

# Optional local owner override.
LOCAL_OWNER=0xYOUR_LOCAL_OWNER

# Sepolia
SEPOLIA_PRIVATE_KEY=0xYOUR_SEPOLIA_PRIVATE_KEY
SEPOLIA_OWNER=0xYOUR_SEPOLIA_OWNER

# Optimism
OPTIMISM_PRIVATE_KEY=0xYOUR_OPTIMISM_PRIVATE_KEY
OPTIMISM_OWNER=0xYOUR_OPTIMISM_OWNER
